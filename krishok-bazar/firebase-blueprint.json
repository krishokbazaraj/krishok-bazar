{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An organic product item in Krishok Bazar",
      "type": "object",
      "properties": {
        "id": { "type": "number", "description": "The unique numeric ID" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "cat": { "type": "string" },
        "farmer": { "type": "string" },
        "farmerId": { "type": "number" },
        "img": { "type": "string" },
        "gallery": { "type": "array" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "weightOptions": { "type": "array" },
        "isBestSeller": { "type": "boolean" }
      },
      "required": ["id", "title", "slug", "price", "unit", "cat", "farmer", "farmerId", "img"]
    },
    "Farmer": {
      "title": "Farmer",
      "description": "A verified farmer in Krishok Bazar",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "products": { "type": "string" },
        "rating": { "type": "number" },
        "sales": { "type": "number" },
        "avatar": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "verified": { "type": "boolean" }
      },
      "required": ["id", "name", "location", "products", "rating", "sales", "avatar", "gender", "verified"]
    },
    "Video": {
      "title": "Video",
      "description": "Farmland update video URL",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "url": { "type": "string" },
        "title": { "type": "string" }
      },
      "required": ["id", "url", "title"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A registered customer profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "name", "phone", "address", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed in Krishok Bazar",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "customerEmail": { "type": "string" },
        "deliveryArea": { "type": "string" },
        "shippingCost": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivered", "completed"] }
      },
      "required": ["id", "items", "total", "customerName", "customerPhone", "customerAddress", "customerEmail", "deliveryArea", "shippingCost", "date", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "A collection containing available fresh organic products"
    },
    "/farmers/{farmerId}": {
      "schema": "Farmer",
      "description": "Registered and pending farmers list"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Weekly farmland live videos uploaded by admin"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer profiles including name, email, phone, and default address"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Unbiased client order placements"
    }
  }
}
