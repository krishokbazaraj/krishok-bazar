rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // DefaultCatch-all denies all access by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Authentication Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      return isEmailVerified() && request.auth.token.email == "krishokbazar.com@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // -------- CUSTOMERS COLLECTION --------
    match /customers/{customerId} {
      allow read: if isSignedIn() && request.auth.uid == customerId;
      allow create: if isSignedIn() && request.auth.uid == customerId && isValidCustomer(request.resource.data);
      allow update: if isSignedIn() && request.auth.uid == customerId && isValidCustomer(request.resource.data);
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == customerId);
    }
    
    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'phone', 'address', 'uid', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() <= 150 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.address is string && data.address.size() <= 500 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }
    
    // -------- PRODUCTS COLLECTION --------
    match /products/{productId} {
      allow read: if true; // Publicly readable for marketplace browsing
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }
    
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'title', 'slug', 'price', 'unit', 'cat', 'farmer', 'farmerId', 'img']) &&
             data.keys().size() >= 9 &&
             data.id is int &&
             data.title is string && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() <= 200 &&
             data.price is int && data.price >= 0 &&
             data.unit is string && data.unit.size() <= 50 &&
             data.cat is string && data.cat.size() <= 50 &&
             data.farmer is string && data.farmer.size() <= 100 &&
             data.farmerId is int &&
             data.img is string && data.img.size() <= 2000;
    }
    
    // -------- FARMERS COLLECTION --------
    match /farmers/{farmerId} {
      allow read: if true; // Anyone can view verified farmers on the platform
      allow create: if isValidFarmer(request.resource.data) && request.resource.data.verified == false; // Pending review
      allow update: if isAdmin() || isValidFarmer(request.resource.data); // Let farmers update profiles & avatars
      allow delete: if isAdmin();
    }
    
    function isValidFarmer(data) {
      return data.keys().hasAll(['id', 'name', 'location', 'products', 'rating', 'sales', 'avatar', 'gender', 'verified']) &&
             data.keys().size() >= 9 &&
             data.id is int &&
             data.name is string && data.name.size() <= 100 &&
             data.location is string && data.location.size() <= 100 &&
             data.products is string && data.products.size() <= 300 &&
             (data.rating is float || data.rating is int) &&
             data.sales is int &&
             data.avatar is string && data.avatar.size() <= 2000 &&
             data.gender is string && (data.gender == 'male' || data.gender == 'female') &&
             data.verified is bool;
    }
    
    // -------- VIDEOS COLLECTION --------
    match /videos/{videoId} {
      allow read: if true; // Anyone can see live farm updates
      allow create, update: if isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isAdmin();
    }
    
    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'url', 'title']) &&
             data.keys().size() == 3 &&
             data.id is int &&
             data.url is string && data.url.size() <= 100 &&
             data.title is string && data.title.size() <= 200;
    }
    
    // -------- ORDERS COLLECTION --------
    match /orders/{orderId} {
      allow read: if true; // Public access for client state and status tracking
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAdmin() || (
        isValidOrder(request.resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        (request.resource.data.status in ['pending', 'confirmed', 'packed', 'shipped', 'out_for_delivery', 'delivered', 'completed'])
      );
      allow delete: if isAdmin();
    }
    
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'items', 'total', 'customerName', 'customerPhone', 'customerAddress', 'date', 'status', 'customerEmail', 'deliveryArea', 'shippingCost']) &&
             data.keys().size() == 11 &&
             data.id is string && data.id.size() <= 50 &&
             data.items is list && data.items.size() <= 100 &&
             (data.total is float || data.total is int) && data.total >= 0 &&
             data.customerName is string && data.customerName.size() <= 150 &&
             data.customerPhone is string && data.customerPhone.size() <= 50 &&
             data.customerAddress is string && data.customerAddress.size() <= 500 &&
             data.customerEmail is string && data.customerEmail.size() <= 100 &&
             data.deliveryArea is string && data.deliveryArea.size() <= 100 &&
             (data.shippingCost is float || data.shippingCost is int) && data.shippingCost >= 0 &&
             data.date is string && data.date.size() <= 100 &&
             data.status is string && (data.status in ['pending', 'confirmed', 'packed', 'shipped', 'out_for_delivery', 'delivered', 'completed']);
    }
  }
}
