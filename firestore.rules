rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // DefaultCatch-all denies all access by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Authentication Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "krishokbazar.com@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // -------- CUSTOMERS COLLECTION --------
    match /customers/{customerId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == customerId);
      allow create, update: if isValidCustomer(request.resource.data);
      allow delete: if isAdmin();
    }
    
    function isValidCustomer(data) {
      return data.name is string && data.name.size() <= 150 &&
             data.phone is string && data.phone.size() <= 100 &&
             data.address is string && data.address.size() <= 1000;
    }
    
    // -------- PRODUCTS COLLECTION --------
    match /products/{productId} {
      allow read: if true; // Publicly readable for marketplace browsing
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }
    
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'title', 'slug', 'price', 'unit', 'cat', 'farmer', 'farmerId', 'img']) &&
             data.keys().size() >= 9 &&
             data.id is int &&
             data.title is string && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() <= 200 &&
             (data.price is int || data.price is float) && data.price >= 0 &&
             data.unit is string && data.unit.size() <= 50 &&
             data.cat is string && data.cat.size() <= 50 &&
             data.farmer is string && data.farmer.size() <= 100 &&
             data.farmerId is int &&
             data.img is string;
    }
    
    // -------- FARMERS COLLECTION --------
    match /farmers/{farmerId} {
      allow read: if true; // Anyone can view verified farmers on the platform
      allow create: if isAdmin() || (isValidFarmer(request.resource.data) && request.resource.data.verified == false); // Pending review
      allow update: if isAdmin() || isValidFarmer(request.resource.data); // Let farmers update profiles & avatars
      allow delete: if isAdmin();
    }
    
    function isValidFarmer(data) {
      return data.keys().hasAll(['id', 'name', 'location', 'products', 'rating', 'sales', 'avatar', 'gender', 'verified']) &&
             data.keys().size() >= 9 &&
             data.id is int &&
             data.name is string && data.name.size() <= 100 &&
             data.location is string && data.location.size() <= 100 &&
             data.products is string && data.products.size() <= 300 &&
             (data.rating is float || data.rating is int) &&
             data.sales is int &&
             data.avatar is string && data.avatar.size() <= 2000 &&
             data.gender is string && (data.gender == 'male' || data.gender == 'female') &&
             data.verified is bool;
    }
    
    // -------- VIDEOS COLLECTION --------
    match /videos/{videoId} {
      allow read: if true; // Anyone can see live farm updates
      allow create, update: if isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isAdmin();
    }
    
    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'url', 'title']) &&
             data.keys().size() == 3 &&
             data.id is int &&
             data.url is string && data.url.size() <= 100 &&
             data.title is string && data.title.size() <= 200;
    }
    
    // -------- ORDERS COLLECTION --------
    match /orders/{orderId} {
      allow read: if true; // Public access for client state and status tracking
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAdmin() || (
        isValidOrder(request.resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        (request.resource.data.status in ['pending', 'confirmed', 'packed', 'shipped', 'out_for_delivery', 'delivered', 'completed'])
      );
      allow delete: if isAdmin();
    }
    
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'items', 'total', 'customerName', 'customerPhone', 'customerAddress', 'date', 'status', 'customerEmail', 'deliveryArea', 'shippingCost']) &&
             data.keys().size() == 11 &&
             data.id is string && data.id.size() <= 50 &&
             data.items is list && data.items.size() <= 100 &&
             (data.total is float || data.total is int) && data.total >= 0 &&
             data.customerName is string && data.customerName.size() <= 150 &&
             data.customerPhone is string && data.customerPhone.size() <= 50 &&
             data.customerAddress is string && data.customerAddress.size() <= 500 &&
             data.customerEmail is string && data.customerEmail.size() <= 100 &&
             data.deliveryArea is string && data.deliveryArea.size() <= 100 &&
             (data.shippingCost is float || data.shippingCost is int) && data.shippingCost >= 0 &&
             data.date is string && data.date.size() <= 100 &&
             data.status is string && (data.status in ['pending', 'confirmed', 'packed', 'shipped', 'out_for_delivery', 'delivered', 'completed']);
    }

    // -------- HERO BANNERS COLLECTION --------
    match /hero_banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // -------- OFFERS COLLECTION --------
    match /offers/{offerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // -------- SITE CONTENT COLLECTION --------
    match /site_content/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // -------- FARMER POSTS COLLECTION --------
    match /farmer_posts/{postId} {
      allow read: if true; // Publicly readable feed
      allow create: if isValidFarmerPost(request.resource.data);
      allow update: if true; // Allow client-side likes, comments, and edits
      allow delete: if true; // Allow farmers to delete their posts
    }
    
    function isValidFarmerPost(data) {
      return data.keys().hasAll(['farmerId', 'farmerName', 'farmerAvatar', 'body', 'timestamp', 'likes', 'comments']) &&
             data.farmerId is int &&
             data.farmerName is string && data.farmerName.size() <= 200 &&
             data.body is string && data.body.size() <= 8000 &&
             data.timestamp is string && data.timestamp.size() <= 100 &&
             data.likes is int && data.likes >= 0 &&
             data.comments is list;
    }

    // -------- REVIEWS COLLECTION --------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if isAdmin() || isValidReview(request.resource.data);
      allow delete: if isAdmin();
    }
    
    function isValidReview(data) {
      return data.keys().hasAll(['id', 'user', 'loc', 'rating', 'date', 'text']) &&
             (data.id is int || data.id is float) &&
             data.user is string && data.user.size() <= 150 &&
             data.loc is string && data.loc.size() <= 150 &&
             (data.rating is int || data.rating is float) &&
             data.date is string && data.date.size() <= 100 &&
             data.text is string && data.text.size() <= 8000;
    }

    // -------- SUBSCRIPTIONS COLLECTION --------
    match /subscriptions/{subId} {
      allow read: if isAdmin();
      allow create, update: if isValidSubscription(request.resource.data);
      allow delete: if isAdmin();
    }
    
    function isValidSubscription(data) {
      return data.status is string && data.status.size() <= 100;
    }
  }
}
